# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ringpaw?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# Google OAuth (for NextAuth + Calendar)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Vapi.ai (phone numbers + voice AI - free phone provisioning)
VAPI_API_KEY=""

# Twilio (SMS notifications only - not needed for phone numbers)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_MESSAGING_SERVICE_SID=""

# OpenAI (for SMS intent parsing)
OPENAI_API_KEY=""

# Calendly
CALENDLY_CLIENT_ID=""
CALENDLY_CLIENT_SECRET=""

# Cal.com
CALCOM_API_KEY=""

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
