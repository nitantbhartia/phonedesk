# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ringpaw?schema=public"

# NextAuth
NEXTAUTH_URL="https://ringpaw.com"
NEXTAUTH_SECRET="your-secret-here"
AUTH_SECRET="optional-alias-for-nextauth-secret"

# Google OAuth (for NextAuth + Calendar)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Retell AI (voice AI + phone numbers)
RETELL_API_KEY=""
RETELL_MODEL="gemini-2.5-flash"
RETELL_WEBHOOK_SECRET=""

# Twilio (SMS messaging)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
# Optional: set to false to disable SMS entirely
SMS_ENABLED="true"

# Gemini (for SMS intent parsing)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# Calendly
CALENDLY_CLIENT_ID=""
CALENDLY_CLIENT_SECRET=""

# Cal.com
CALCOM_API_KEY=""

# App URL
NEXT_PUBLIC_APP_URL="https://ringpaw.com"
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Stripe Billing
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_STARTER_PRICE_ID=""
STRIPE_PRO_PRICE_ID=""
STRIPE_BUSINESS_PRICE_ID=""

# Owner dashboard access (comma-separated emails)
OWNER_DASHBOARD_EMAILS=""
# Optional: show Owner nav link in the sidebar for these emails
NEXT_PUBLIC_OWNER_DASHBOARD_EMAILS=""

# Email (Resend) — used for lead notifications and transactional emails
RESEND_API_KEY=""
RESEND_FROM="RingPaw <noreply@ringpaw.com>"
# Optional: separate secret for signing live demo tokens (falls back to NEXTAUTH_SECRET)
DEMO_TOKEN_SECRET=""
