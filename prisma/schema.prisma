generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Core models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  business      Business?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Business {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  ownerName       String
  email           String?
  phone           String?
  city            String?
  state           String?
  address         String?
  timezone        String   @default("America/Los_Angeles")
  businessHours   Json?    // { mon: { open: "09:00", close: "17:00" }, ... }
  bookingMode     BookingMode @default(SOFT)
  vaccinePolicy   VaccinePolicy @default(OFF)
  isActive        Boolean  @default(false)
  onboardingStep  Int      @default(1)
  onboardingComplete Boolean @default(false)

  phoneNumber     PhoneNumber?
  services        Service[]
  calendarConnections CalendarConnection[]
  calls           Call[]
  appointments    Appointment[]
  customers       Customer[]
  retellConfig    RetellConfig?
  waitlistEntries WaitlistEntry[]
  intakeForms     IntakeForm[]
  pricingRules    PricingRule[]
  rebookingConfig RebookingConfig?
  behaviorLogs    BehaviorLog[]
  reviewRequests  ReviewRequest[]
  breedRecommendations BreedRecommendation[]
  groomers        Groomer[]
  googleReviewUrl String?        // direct Google review link
  plan            Plan     @default(STARTER)
  stripeCustomerId String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId    String?
  stripeSubscriptionStatus String?
  bookingsCount    Int     @default(0) // total bookings Pip has ever made for this business
  billingConsentGiven Boolean @default(false) // groomer checked the billing consent box at checkout
  adminApprovedGoLive Boolean @default(false) // admin must approve before business can go live

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum Plan {
  STARTER
  PRO
  BUSINESS
}

enum BookingMode {
  HARD
  SOFT
}

enum VaccinePolicy {
  OFF        // No vaccine check (default, existing behavior)
  FLAG_ONLY  // Ask about vaccines, always book, note status
  REQUIRE    // Ask about vaccines, block booking if hard no
}

model PhoneNumber {
  id            String        @id @default(cuid())
  businessId    String        @unique
  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  number        String        @unique
  retellPhoneNumber String?    @unique // Retell phone number (E.164 identifier)
  provider      PhoneProvider @default(RETELL)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
}

enum PhoneProvider {
  RETELL
  TWILIO  // future: if owner brings own Twilio number
}

model DemoNumber {
  id                String              @id @default(cuid())
  number            String              @unique // E.164, e.g. +16195550100
  retellPhoneNumber String              @unique // Retell E.164 identifier
  sessions          DemoSession[]
  publicAttempts    PublicDemoAttempt[]
  createdAt         DateTime            @default(now())
}

model DemoSession {
  id           String     @id @default(cuid())
  demoNumberId String
  demoNumber   DemoNumber @relation(fields: [demoNumberId], references: [id])
  businessId   String     @unique // one active session per business at a time
  expiresAt    DateTime
  createdAt    DateTime   @default(now())
}

// Tracks public (unauthenticated) demo attempts for IP-based and phone-based rate limiting
model PublicDemoAttempt {
  id           String    @id @default(cuid())
  ip           String
  sessionToken String    @unique @default(cuid())
  demoNumberId String?     // which demo number was assigned
  demoNumber   DemoNumber? @relation(fields: [demoNumberId], references: [id])
  callerPhone  String?     // set when call_started webhook fires; used for phone-based rate limiting
  leadId       String?     // verified DemoLead that unlocked this attempt
  lead         DemoLead?   @relation(fields: [leadId], references: [id])
  startedAt    DateTime  @default(now())
  expiresAt    DateTime  // session expires after 30 min

  @@index([ip])
  @@index([callerPhone])
  @@index([leadId])
}

// A qualified prospect who has verified their email to access the live demo
model DemoLead {
  id            String               @id @default(cuid())
  email         String               @unique
  contactName   String?
  businessName  String?
  phone         String?
  ipAtCreation  String
  verifiedAt    DateTime?            // set when magic link is clicked
  lastDemoAt    DateTime?            // set when they successfully start a live demo
  cooldownUntil DateTime?            // they cannot start another demo until this time
  attempts      PublicDemoAttempt[]
  tokens        DemoMagicToken[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([email])
  @@index([cooldownUntil])
}

// Single-use email magic link token for verifying a DemoLead
model DemoMagicToken {
  id        String    @id @default(cuid())
  leadId    String
  lead      DemoLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  token     String    @unique @default(cuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
}

model Service {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  price        Float
  duration     Int      // in minutes
  isActive     Boolean  @default(true)
  isAddon      Boolean  @default(false) // if true, AI will offer this as an upsell add-on
  bookingMode  BookingMode? // override business default
  pricingRules PricingRule[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CalendarConnection {
  id            String         @id @default(cuid())
  businessId    String
  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  provider      CalendarProvider
  isPrimary     Boolean        @default(false)
  accessToken   String?        @db.Text
  refreshToken  String?        @db.Text
  tokenExpiry   DateTime?
  calendarId    String?        // e.g., Google Calendar ID
  externalUrl   String?        // e.g., Calendly scheduling URL
  metadata      Json?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum CalendarProvider {
  GOOGLE
  SQUARE
  ACUITY
  MOEGO
}

model RetellConfig {
  id                 String   @id @default(cuid())
  businessId         String   @unique
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  agentId            String?  // Retell agent ID
  llmId              String?  // Retell LLM (Response Engine) ID
  systemPrompt       String?  @db.Text
  voiceId            String?
  greeting           String?  @db.Text
  fallbackMessage    String?  @db.Text
  personality        Json?    // { tone, style, language, customInstructions }
  isActive           Boolean  @default(true)
  rebookingAgentId   String?  // Retell agent ID for outbound rebooking calls
  rebookingLlmId     String?  // Retell LLM ID for outbound rebooking calls
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Call {
  id              String      @id @default(cuid())
  businessId      String
  business        Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  retellCallId    String?     @unique
  callerPhone     String?
  callerName      String?
  duration        Int?        // seconds
  transcript      String?     @db.Text
  transcriptObject Json?      // structured transcript from Retell (array of turns with tool calls)
  summary         String?     @db.Text
  status          CallStatus  @default(IN_PROGRESS)
  extractedData   Json?       // { customerName, dogName, breed, size, service, preferredTime }
  appointmentId   String?
  appointment     Appointment? @relation(fields: [appointmentId], references: [id])
  recordingUrl    String?
  isTestCall      Boolean     @default(false) // true if made before onboarding complete; excluded from usage counts
  isOutbound      Boolean     @default(false) // true for AI-initiated outbound rebooking calls
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum CallStatus {
  IN_PROGRESS
  COMPLETED
  MISSED
  FAILED
  NO_BOOKING
}

model Appointment {
  id              String            @id @default(cuid())
  businessId      String
  business        Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerName    String
  customerPhone   String?
  petName         String?
  petBreed        String?
  petSize         PetSize?
  serviceName     String?
  servicePrice    Float?
  startTime       DateTime
  endTime         DateTime
  status          AppointmentStatus @default(PENDING)
  bookingMode     BookingMode       @default(SOFT)
  calendarEventId String?           // external calendar event ID
  confirmLink     String?
  notes           String?           @db.Text
  vaccineStatus   String?           // confirmed, uncertain, unvaccinated_flagged, exemption_bordetella, exemption_rabies
  reminderSent    Boolean           @default(false)
  reminder48hSent Boolean           @default(false)
  onMyWaySent     Boolean           @default(false)
  confirmedAt     DateTime?         // when the customer confirmed via SMS/link
  noShowMarkedAt  DateTime?         // when marked as no-show
  groomingStatus  GroomingStatus?   // Feature 2: live appointment status
  groomingStatusAt DateTime?        // when status was last updated
  pickupNotifiedAt DateTime?        // when pickup SMS was sent
  completedAt     DateTime?         // when grooming was completed
  rebookSent      Boolean          @default(false) // Feature 5: rebooking reminder sent
  rebookInterval  Int?             // days until next groom (breed-specific)
  reviewRequested Boolean          @default(false) // Feature 7: review request sent
  isTestBooking   Boolean          @default(false) // true if booked via a demo/test call; excluded from billing triggers
  groomerToken    String?           @unique  // public token for groomer status update link
  groomerId       String?
  groomer         Groomer?         @relation(fields: [groomerId], references: [id], onDelete: SetNull)
  calls           Call[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Customer {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  phone           String
  name            String
  visitCount      Int      @default(0)
  vipFlag         Boolean  @default(false)
  notes           String?  @db.Text
  lastServiceName String?
  lastVisitAt     DateTime?
  lastContactAt   DateTime?
  lastCallSummary String?  @db.Text
  lastOutcome     String?
  noShowCount     Int      @default(0)
  squareCustomerId String?  // Square CRM customer ID for write-back
  moegoCustomerId  String?  // MoeGo CRM customer ID for write-back
  preferredGroomerId String?
  preferredGroomer   Groomer?  @relation(fields: [preferredGroomerId], references: [id], onDelete: SetNull)
  pets            Pet[]
  behaviorLogs    BehaviorLog[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([businessId, phone])
}

model Pet {
  id            String   @id @default(cuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name          String
  breed         String?
  size          PetSize?
  notes         String?  @db.Text
  behaviorLogs  BehaviorLog[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([customerId, name])
}

enum PetSize {
  SMALL
  MEDIUM
  LARGE
  XLARGE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model SmsLog {
  id          String    @id @default(cuid())
  direction   SmsDirection
  fromNumber  String
  toNumber    String
  body        String    @db.Text
  messageSid  String?   // Retell chat ID or message identifier
  intent      String?   // parsed intent for owner commands
  businessId  String?
  createdAt   DateTime  @default(now())
}

enum SmsDirection {
  INBOUND
  OUTBOUND
}

model WaitlistEntry {
  id            String    @id @default(cuid())
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerName  String
  customerPhone String
  petName       String?
  petBreed      String?
  petSize       PetSize?
  serviceName   String?
  preferredDate DateTime  // the date they want
  preferredTime String?   // e.g., "morning", "afternoon", or "10:00"
  notes         String?
  status        WaitlistStatus @default(WAITING)
  notifiedAt    DateTime?
  bookedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum WaitlistStatus {
  WAITING
  NOTIFIED    // we texted them about an opening
  BOOKED      // they took the slot
  EXPIRED     // the date passed
  DECLINED    // they said no
}

// Feature 2: Appointment Status ("Is My Dog Ready?")
enum GroomingStatus {
  CHECKED_IN
  IN_PROGRESS
  READY_FOR_PICKUP
  PICKED_UP
}

// Feature 3: New Client Intake Form
model IntakeForm {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointmentId   String?  @unique
  customerPhone   String
  customerName    String
  petName         String?
  petBreed        String?
  petAge          String?
  petWeight       String?
  vaccinated      Boolean?
  vetName         String?
  vetPhone        String?
  temperament     String?  // e.g. "friendly", "anxious", "aggressive"
  biteHistory     Boolean?
  allergies       String?
  emergencyName   String?
  emergencyPhone  String?
  specialNotes    String?  @db.Text
  photoUrl        String?
  completed       Boolean  @default(false)
  token           String   @unique @default(cuid()) // for public access link
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Feature 4: Breed × Service Pricing Matrix
model PricingRule {
  id          String    @id @default(cuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceId   String
  service     Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  breed       String?   // null = default price for this service
  size        PetSize?  // null = any size
  price       Float
  notes       String?   // e.g. "add $30 for dematting"
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([businessId, serviceId, breed, size])
}

// Breed-Based Service Recommendation Engine
model BreedRecommendation {
  id                        String   @id @default(cuid())
  businessId                String
  business                  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  breedKeyword              String   // lowercase substring to match, e.g. "poodle"
  recommendedServiceKeyword String   // substring of service name, e.g. "full groom"
  reason                    String   // shown to the AI to explain the recommendation naturally
  priority                  Int      @default(0) // higher = listed first in prompt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, breedKeyword])
}

// Feature 5: Rebooking Engine
model RebookingConfig {
  id              String   @id @default(cuid())
  businessId      String   @unique
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  enabled         Boolean  @default(true)
  defaultInterval Int      @default(42) // days between grooms (6 weeks)
  reminderDaysBefore Int   @default(7)  // send reminder X days before due
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Feature 6: Incident / Behavioral Logging
model BehaviorLog {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  petId         String?
  pet           Pet?     @relation(fields: [petId], references: [id], onDelete: SetNull)
  appointmentId String?
  petName       String
  severity      BehaviorSeverity @default(NOTE)
  note          String   @db.Text
  tags          String[] // e.g. ["muzzle_required", "anxious", "biting"]
  createdAt     DateTime @default(now())
}

enum BehaviorSeverity {
  NOTE        // general observation
  CAUTION     // needs extra care
  HIGH_RISK   // requires owner discussion before booking
}

// Groomers / Staff
model Groomer {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name          String
  phone         String?  // optional — for sending groomer link via SMS
  specialties   String[] // e.g. ["doodles", "hand stripping", "cats"]
  isActive      Boolean  @default(true)
  appointments  Appointment[]
  preferredBy   Customer[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([businessId, name])
}

// Feature 7: Google Review Automation
model ReviewRequest {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerPhone String
  customerName  String
  petName       String?
  appointmentId String?
  sentAt        DateTime @default(now())
  clicked       Boolean  @default(false)
  clickedAt     DateTime?
}
