generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Core models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  business      Business?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Business {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  ownerName       String
  email           String?
  phone           String?
  city            String?
  state           String?
  address         String?
  timezone        String   @default("America/Los_Angeles")
  businessHours   Json?    // { mon: { open: "09:00", close: "17:00" }, ... }
  bookingMode     BookingMode @default(SOFT)
  isActive        Boolean  @default(false)
  onboardingStep  Int      @default(1)
  onboardingComplete Boolean @default(false)

  phoneNumber     PhoneNumber?
  services        Service[]
  calendarConnections CalendarConnection[]
  calls           Call[]
  appointments    Appointment[]
  customers       Customer[]
  retellConfig    RetellConfig?
  waitlistEntries WaitlistEntry[]
  plan            Plan     @default(STARTER)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum Plan {
  STARTER
  PRO
  BUSINESS
}

enum BookingMode {
  HARD
  SOFT
}

model PhoneNumber {
  id            String        @id @default(cuid())
  businessId    String        @unique
  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  number        String        @unique
  retellPhoneNumber String?    @unique // Retell phone number (E.164 identifier)
  provider      PhoneProvider @default(RETELL)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
}

enum PhoneProvider {
  RETELL
  TWILIO  // future: if owner brings own Twilio number
}

model Service {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float
  duration    Int      // in minutes
  isActive    Boolean  @default(true)
  bookingMode BookingMode? // override business default
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CalendarConnection {
  id            String         @id @default(cuid())
  businessId    String
  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  provider      CalendarProvider
  isPrimary     Boolean        @default(false)
  accessToken   String?        @db.Text
  refreshToken  String?        @db.Text
  tokenExpiry   DateTime?
  calendarId    String?        // e.g., Google Calendar ID
  externalUrl   String?        // e.g., Calendly scheduling URL
  metadata      Json?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum CalendarProvider {
  GOOGLE
  CALENDLY
  CALCOM
}

model RetellConfig {
  id              String   @id @default(cuid())
  businessId      String   @unique
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  agentId         String?  // Retell agent ID
  llmId           String?  // Retell LLM (Response Engine) ID
  systemPrompt    String?  @db.Text
  voiceId         String?
  greeting        String?  @db.Text
  fallbackMessage String?  @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Call {
  id              String      @id @default(cuid())
  businessId      String
  business        Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  retellCallId    String?     @unique
  callerPhone     String?
  callerName      String?
  duration        Int?        // seconds
  transcript      String?     @db.Text
  summary         String?     @db.Text
  status          CallStatus  @default(IN_PROGRESS)
  extractedData   Json?       // { customerName, dogName, breed, size, service, preferredTime }
  appointmentId   String?
  appointment     Appointment? @relation(fields: [appointmentId], references: [id])
  recordingUrl    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum CallStatus {
  IN_PROGRESS
  COMPLETED
  MISSED
  FAILED
  NO_BOOKING
}

model Appointment {
  id              String            @id @default(cuid())
  businessId      String
  business        Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerName    String
  customerPhone   String?
  petName         String?
  petBreed        String?
  petSize         PetSize?
  serviceName     String?
  servicePrice    Float?
  startTime       DateTime
  endTime         DateTime
  status          AppointmentStatus @default(PENDING)
  bookingMode     BookingMode       @default(SOFT)
  calendarEventId String?           // external calendar event ID
  confirmLink     String?
  notes           String?           @db.Text
  reminderSent    Boolean           @default(false)
  reminder48hSent Boolean           @default(false)
  confirmedAt     DateTime?         // when the customer confirmed via SMS/link
  noShowMarkedAt  DateTime?         // when marked as no-show
  calls           Call[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Customer {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  phone           String
  name            String
  visitCount      Int      @default(0)
  vipFlag         Boolean  @default(false)
  notes           String?  @db.Text
  lastServiceName String?
  lastVisitAt     DateTime?
  lastContactAt   DateTime?
  lastCallSummary String?  @db.Text
  lastOutcome     String?
  pets            Pet[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([businessId, phone])
}

model Pet {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name        String
  breed       String?
  size        PetSize?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([customerId, name])
}

enum PetSize {
  SMALL
  MEDIUM
  LARGE
  XLARGE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model SmsLog {
  id          String    @id @default(cuid())
  direction   SmsDirection
  fromNumber  String
  toNumber    String
  body        String    @db.Text
  messageSid  String?   // Retell chat ID or message identifier
  intent      String?   // parsed intent for owner commands
  businessId  String?
  createdAt   DateTime  @default(now())
}

enum SmsDirection {
  INBOUND
  OUTBOUND
}

model WaitlistEntry {
  id            String    @id @default(cuid())
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerName  String
  customerPhone String
  petName       String?
  petBreed      String?
  petSize       PetSize?
  serviceName   String?
  preferredDate DateTime  // the date they want
  preferredTime String?   // e.g., "morning", "afternoon", or "10:00"
  notes         String?
  status        WaitlistStatus @default(WAITING)
  notifiedAt    DateTime?
  bookedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum WaitlistStatus {
  WAITING
  NOTIFIED    // we texted them about an opening
  BOOKED      // they took the slot
  EXPIRED     // the date passed
  DECLINED    // they said no
}
